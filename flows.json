    {
        "id": "1e86fc94b6f93832",
        "type": "function",
        "z": "bdd14ed9aa832926",
        "name": "Calculate %s",
        "func": "\nlet data = msg.payload;\n\nlet p = data.col4 / 100;\n\nfunction key_pct(k, places) {\n    data[k] = (data[k] * p).toFixed(places);\n}\n\nkey_pct(\"col6\", 0);\nkey_pct(\"col7\", 0);\nkey_pct(\"col8\", 0);\nkey_pct(\"col9\", 5);\n\nmsg.payload = data;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
