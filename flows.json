    {
        "id": "1e86fc94b6f93832",
        "type": "function",
        "z": "a9a6010b932de479",
        "name": "Calculate %s",
        "func": "\nlet data = msg.payload;\n\nlet p = data.effort_pct / 100;\n\nfunction key_pct(k, places) {\n    data[k] = (data[k] * p).toFixed(places);\n}\n\nkey_pct(\"tokens_in\", 0);\nkey_pct(\"tokens_out\", 0);\nkey_pct(\"tokens_total\", 0);\nkey_pct(\"cost_total\", 5);\n\nmsg.payload = data;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 300,
        "wires": [
